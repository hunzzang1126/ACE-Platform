{
  "name": "pencildev",
  "displayName": "Pencil",
  "description": "A VS Code extension for Pencil design files",
  "version": "0.6.30",
  "publisher": "highagency",
  "author": "High Agency",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://pencil.dev",
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "pencil",
    "design",
    "preview"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "main": "./out/main.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build:mcp": "cd ../../servers/mcp && ./build-mcp-cross-platform.sh",
    "build:dev": "npm run build:mcp && rm -rf out && vite build && rm -f out/mcp-server-* && cp ../../servers/mcp/mcp-server-* out/ && cp -r assets out && mkdir -p out/data && cp ../../lib/editor/data/*.pen out/data/",
    "build": "rm -rf out && vite build && rm -f out/mcp-server-* && cp ../../servers/mcp/mcp-server-* out/ && cp -r assets out && mkdir -p out/data && cp ../../lib/editor/data/*.pen out/data/",
    "package": "npm run build && vsce package --follow-symlinks --dependencies",
    "package:prerelease": "npm run build && vsce package --follow-symlinks --dependencies --pre-release",
    "publish:vscode": "vsce publish",
    "publish:vscode:prerelease": "vsce publish --pre-release",
    "publish:ovsx": "ovsx publish",
    "publish:ovsx:prerelease": "ovsx publish --pre-release",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org high-agency --project vscode-extension ${SENTRY_AUTH_TOKEN:+--auth-token \"$SENTRY_AUTH_TOKEN\"} ./out && sentry-cli sourcemaps upload --org high-agency --project vscode-extension ${SENTRY_AUTH_TOKEN:+--auth-token \"$SENTRY_AUTH_TOKEN\"} ./out",
    "lint": "biome check"
  },
  "contributes": {
    "configuration": {
      "title": "Pencil",
      "properties": {
        "pencil.mcp.integrations.claudeCode": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Claude Code VSCode Extension**. When enabled, Claude Code can access Pencil design tools.",
          "order": 3
        },
        "pencil.mcp.integrations.claudeCodeCLI": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Claude Code CLI** (global `claude` command). When enabled, the global Claude CLI can access Pencil design tools.",
          "order": 4
        },
        "pencil.mcp.integrations.codex": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Codex VSCode Extension** (OpenAI). When enabled, Codex can access Pencil design tools.",
          "order": 5
        },
        "pencil.mcp.integrations.codexCLI": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Codex CLI** (global `codex` command). When enabled, the global Codex CLI can access Pencil design tools.",
          "order": 6
        },
        "pencil.mcp.integrations.geminiCLI": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Google Gemini CLI** (`~/.gemini/settings.json`) (global `gemini` command). When enabled, Gemini CLI can access Pencil design tools.",
          "order": 7
        },
        "pencil.mcp.integrations.windsurfIDE": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Windsurf IDE** (Codeium) (`~/.codeium/windsurf/mcp_config.json`). When enabled, Windsurf IDE can access Pencil design tools.",
          "order": 8
        },
        "pencil.mcp.integrations.antigravityIDE": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Antigravity IDE** (`~/.gemini/antigravity/mcp_config.json`). When enabled, Antigravity IDE can access Pencil design tools. If you do not see Pencil MCP in \"Manage MCPs\" view, hit the \"Refresh\" button top right.",
          "order": 10
        },
        "pencil.mcp.integrations.openCodeCLI": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **OpenCode CLI** (global `opencode` command). When enabled, the global OpenCode CLI can access Pencil design tools.",
          "order": 11
        },
        "pencil.mcp.integrations.kiroCLI": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Kiro CLI** (`~/.kiro/settings/mcp.json`) (global `kiro-cli` command). When enabled, Kiro CLI can access Pencil design tools.",
          "order": 12
        },
        "pencil.mcp.integrations.claudeDesktop": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Install Pencil MCP server to **Claude Desktop**. When enabled, the Claude Desktop can access Pencil design tools.",
          "order": 13
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pencil",
          "title": "Pencil",
          "icon": "./assets/icons/pencil-dark.png"
        }
      ]
    },
    "views": {
      "pencil": [
        {
          "id": "pencil.sidebar",
          "name": "Pencil Recent Files"
        }
      ]
    },
    "icons": {
      "pencil-new": {
        "description": "Pencil New",
        "default": {
          "fontPath": "./out/assets/font/pencil.woff",
          "fontCharacter": "\\E800"
        }
      },
      "pencil-logo": {
        "description": "Pencil Logo",
        "default": {
          "fontPath": "./out/assets/font/pencil.woff",
          "fontCharacter": "\\E801"
        }
      }
    },
    "commands": [
      {
        "command": "pencil.newFile",
        "title": "Pencil: New File",
        "icon": "$(pencil-new)"
      },
      {
        "command": "pencil.toggleDesignMode",
        "title": "Pencil: Toggle Design Mode",
        "icon": "$(screen-full)"
      },
      {
        "command": "pencil.openRawDesignFile",
        "title": "Pencil: Open Design File as Text"
      },
      {
        "command": "pencil.openWelcomeDocument",
        "title": "Pencil: Open Welcome File"
      },
      {
        "command": "pencil.openShadcnDocument",
        "title": "Pencil: Open Shadcn UI File"
      },
      {
        "command": "pencil.openHaloDocument",
        "title": "Pencil: Open Halo File"
      },
      {
        "command": "pencil.openLunarisDocument",
        "title": "Pencil: Open Lunaris File"
      },
      {
        "command": "pencil.openNitroDocument",
        "title": "Pencil: Open Nitro File"
      },
      {
        "command": "pencil.openDemoDocument",
        "title": "Pencil: Open Demo File"
      },
      {
        "command": "pencil.clearRecentFiles",
        "title": "Clear Recent Files",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pencil.clearRecentFiles",
          "when": "view == pencil.sidebar",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "pencil.openRawDesignFile",
          "when": "resourceExtname == '.pen'",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "submenu": "pencil.submenu",
          "group": "navigation"
        }
      ],
      "pencil.submenu": [
        {
          "command": "pencil.newFile"
        },
        {
          "command": "pencil.openWelcomeDocument"
        },
        {
          "command": "pencil.openShadcnDocument"
        },
        {
          "command": "pencil.openHaloDocument"
        },
        {
          "command": "pencil.openLunarisDocument"
        },
        {
          "command": "pencil.openNitroDocument"
        },
        {
          "command": "pencil.openDemoDocument"
        }
      ]
    },
    "submenus": [
      {
        "id": "pencil.submenu",
        "label": "Pencil",
        "icon": "$(pencil-logo)"
      }
    ],
    "keybindings": [
      {
        "command": "pencil.toggleDesignMode",
        "key": "ctrl+shift+\\",
        "mac": "cmd+shift+\\"
      }
    ],
    "customEditors": [
      {
        "viewType": "pencil.designEditor",
        "displayName": "Pencil Design Editor",
        "selector": [
          {
            "filenamePattern": "*.pen"
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "pencil",
        "extensions": [
          ".pen"
        ],
        "aliases": [
          "Pencil"
        ],
        "icon": {
          "light": "./assets/icons/pencil-light.png",
          "dark": "./assets/icons/pencil-dark.png"
        }
      }
    ]
  },
  "icon": "./assets/icons/pencil-logo.png",
  "galleryBanner": {
    "color": "#FFFFFF",
    "theme": "light"
  },
  "preview": false,
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.42",
    "@aws-sdk/client-s3": "^3.940.0",
    "@ha/agent": "file:../../lib/agent",
    "@ha/ipc": "file:../../lib/ipc",
    "@ha/mcp": "file:../../lib/mcp",
    "@ha/pencil-editor": "file:../../lib/pencil-editor",
    "@ha/schema": "file:../../lib/schema",
    "@ha/shared": "file:../../lib/shared",
    "@ha/ws-server": "file:../../servers/ws",
    "@highagency/pencil-skia": "^0.48.1",
    "@sentry/cli": "^2.57.0",
    "@sentry/node": "^10.27.0",
    "@sentry/vite-plugin": "^4.6.1",
    "dotenv": "^17.2.2",
    "eventemitter3": "^5.0.1",
    "js-yaml": "^4.1.0",
    "semver": "^7.7.3",
    "unzipper": "^0.12.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.1.0",
    "@types/semver": "^7.7.1",
    "@types/unzipper": "^0.10.11",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.6.0",
    "glob": "^13.0.0",
    "ovsx": "^0.10.6",
    "rollup-plugin-node-externals": "^8.1.2",
    "typescript": "^5.0.0",
    "vite": "^6.0.7"
  }
}
